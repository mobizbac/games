<!DOCTYPE html>
<html lang="en-us">

<head>
  <meta charset="utf-8">
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <title>Suicide Guy Deluxe Edition Reeyuki</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      overflow: hidden;
      background: #000;
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      color: white;
      height: 100vh;
      width: 100vw;
    }

    #unity-canvas {
      width: 100%;
      height: 100%;
      display: block;
    }

    #loading-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: #0f0f0f;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      transition: opacity 0.8s ease-in-out;
    }

    .loading-container {
      width: 80%;
      max-width: 500px;
      text-align: center;
    }

    .logo {
      font-size: 2rem;
      font-weight: bold;
      margin-bottom: 30px;
      letter-spacing: 4px;
      color: #fff;
      text-transform: uppercase;
    }

    .progress-bar-bg {
      width: 100%;
      height: 4px;
      background: #222;
      border-radius: 2px;
      overflow: hidden;
      margin-top: 20px;
    }

    #progress-bar-fill {
      width: 0%;
      height: 100%;
      background: #fff;
      transition: width 0.2s ease-out;
    }

    .status-text {
      font-size: 0.8rem;
      margin-bottom: 10px;
      font-weight: 400;
      letter-spacing: 2px;
      color: #888;
      text-transform: uppercase;
    }

    .stats {
      margin-top: 15px;
      font-size: 0.7rem;
      color: #555;
      letter-spacing: 1px;
    }
  </style>
</head>

<body>
  <div id="loading-overlay">
    <div class="loading-container">
      <div class="logo">SUICIDE GUY DELUXE EDITION</div>
      <div class="status-text" id="status-text">INITIALIZING...</div>
      <div class="progress-bar-bg">
        <div id="progress-bar-fill"></div>
      </div>
      <div class="stats" id="stats-text">0.00 MB / 0.00 MB (0%)</div>
    </div>
  </div>

  <canvas id="unity-canvas" tabindex="-1"></canvas>

  <script>
    const GITHUB_BASE = "https://cdn.jsdelivr.net/gh/Reeyuki/SuicideGuyDeluxe/";
    const DATA_PREFIX = "Build/d7ce9c28de32f2d3139035252df8b14a";
    const WASM_PREFIX = "Build/bd5761199b02788020f3c66d3c2cfa5f";
    const FRAMEWORK_URL = GITHUB_BASE + "Build/5429fa8a863582b6ba98c18e5369f375.framework.js";
    const LOADER_URL = GITHUB_BASE + "Build/bb0d9ecdb05db3e84da20bd14a4f84dc.loader.js";

    const DATA_CHUNKS = 51;
    const WASM_CHUNKS = 2;

    const TOTAL_DATA_SIZE = 1062489042;
    const TOTAL_WASM_SIZE = 27474257;
    const TOTAL_SIZE = TOTAL_DATA_SIZE + TOTAL_WASM_SIZE;

    let downloadedSize = 0;

    const progressBar = document.getElementById('progress-bar-fill');
    const statsText = document.getElementById('stats-text');
    const statusText = document.getElementById('status-text');
    const overlay = document.getElementById('loading-overlay');

    function updateProgress(chunkSize) {
      downloadedSize += chunkSize;
      const percent = Math.min(100, Math.floor((downloadedSize / TOTAL_SIZE) * 100));
      const downloadedMB = (downloadedSize / (1024 * 1024)).toFixed(2);
      const totalMB = (TOTAL_SIZE / (1024 * 1024)).toFixed(2);

      progressBar.style.width = percent + "%";
      statsText.innerText = `${downloadedMB} MB / ${totalMB} MB (${percent}%)`;
    }

    async function fetchWithProgress(url) {
      const response = await fetch(GITHUB_BASE + url);
      const reader = response.body.getReader();
      const chunks = [];

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        chunks.push(value);
        updateProgress(value.length);
      }

      return new Blob(chunks);
    }

    async function fetchChunk(prefix, index, ext) {
      const suffix = index.toString().padStart(2, '0');
      const url = `${prefix}.file${suffix}.${ext}`;
      return fetchWithProgress(url);
    }

    async function loadChunksParallel(prefix, count, ext, concurrency = 6) {
      const results = new Array(count);
      let nextIndex = 0;
      let active = 0;
      let completed = 0;

      return new Promise((resolve, reject) => {
        function dispatch() {
          while (active < concurrency && nextIndex < count) {
            const i = nextIndex++;
            active++;
            fetchChunk(prefix, i, ext)
              .then(blob => {
                results[i] = blob;
                active--;
                completed++;
                statusText.innerText = `DOWNLOADING ${ext.toUpperCase()} [${completed}/${count}]`;
                if (completed === count) {
                  resolve(new Blob(results));
                } else {
                  dispatch();
                }
              })
              .catch(reject);
          }
        }
        dispatch();
      });
    }

    async function start() {
      try {
        statusText.innerText = "DOWNLOADING DATA...";
        const [dataBlob, wasmBlob] = await Promise.all([
          loadChunksParallel(DATA_PREFIX, DATA_CHUNKS, "data", 6),
          loadChunksParallel(WASM_PREFIX, WASM_CHUNKS, "wasm", 2),
        ]);

        const dataUrl = URL.createObjectURL(dataBlob);
        const codeUrl = URL.createObjectURL(wasmBlob);

        statusText.innerText = "PREPARING ENGINE...";

        const script = document.createElement("script");
        script.src = LOADER_URL;
        script.onload = () => {
          createUnityInstance(document.querySelector("#unity-canvas"), {
            dataUrl: dataUrl,
            frameworkUrl: FRAMEWORK_URL,
            codeUrl: codeUrl,
            streamingAssetsUrl: GITHUB_BASE + "StreamingAssets",
            companyName: "Chubby Pixel Publishing",
            productName: "Suicide Guy Deluxe Edition",
            productVersion: "1.01",
          }, (progress) => {
            if (progress < 1) {
              statusText.innerText = `BOOTING... ${Math.round(progress * 100)}%`;
            } else {
              statusText.innerText = "READY";
              overlay.style.opacity = '0';
              setTimeout(() => overlay.style.display = 'none', 800);
            }
          }).then((unityInstance) => {
            window.unityInstance = unityInstance;
          });
        };
        document.body.appendChild(script);

      } catch (err) {
        console.error("Error loading chunks:", err);
        statusText.innerText = "FAILED TO LOAD ASSETS";
        statusText.style.color = "#ff3333";
      }
    }

    start();
  </script>
</body>

</html>
