<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8"/>

  <meta name="viewport" content="initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, target-densitydpi=device-dpi" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black" />
  <meta name="HandheldFriendly" content="true" />

  <title>Clickteam HTML5 Runtime</title>

  <script>
    if (!document.createElement("canvas").getContext) {
      window.open("http://www.clickteam.com/html5-fallback", "_self");
    }
  </script>

  <script src="https://cdn.jsdelivr.net/gh/TheChillVideoGameNerd/My-FNAF-Ports@main/Security%20Breach%20Fury's%20Rage/src/Runtime.js"></script>

  <style>
    body {
      margin: 0;
      padding: 0;
      background: #fff;
      text-align: center;
      font-family: Arial, sans-serif;
    }

    canvas {
      display: inline-block;
    }
  </style>
</head>

<body>

<div style="display:inline-block; position:relative;">
  <canvas id="MMFCanvas" width="720" height="480">
    Your browser does not support Canvas.
  </canvas>
  <div id="portCredit" style="
    position: absolute;
    bottom: 12px;
    width: 100%;
    text-align: center;
    color: #cccccc;
    font-family: Arial, sans-serif;
    font-size: 13px;
    pointer-events: none;
    user-select: none;
    z-index: 10;
    text-shadow: 0 1px 3px #000;
  "></div>
</div>

<script>
  var canvas = document.getElementById("MMFCanvas");
  var credit = document.getElementById("portCredit");
  var observer = new MutationObserver(function() {
    if (canvas.style.display === "none") credit.style.display = "none";
  });
  observer.observe(canvas, { attributes: true, attributeFilter: ["style"] });
</script>

<script>
window.addEventListener("load", function () {
  new Runtime(
    "MMFCanvas",
    "https://cdn.jsdelivr.net/gh/TheChillVideoGameNerd/My-FNAF-Ports@main/Security%20Breach%20Fury's%20Rage/resources/Security%20Breach%20Fury's%20Rage%20Web%20Port.cch"
  );
});
</script>

</body>
</html>
